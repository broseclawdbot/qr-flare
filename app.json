{
  "expo": {
    "name": "QR Flare",
    "slug": "qr-flare",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A14",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qrflare.app",
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "QR Flare saves your generated QR codes to your photo library.",
        "NSPhotoLibraryUsageDescription": "QR Flare needs access to let you pick a logo for your QR code."
      }
    },
    "android": {
      "package": "com.qrflare.app",
      "permissions": ["READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_AFTER_EAS_INIT"
      }
    },
    "owner": "REPLACE_WITH_YOUR_EXPO_USERNAME"
  }
}
